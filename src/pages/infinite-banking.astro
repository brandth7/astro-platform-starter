---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Infinite Banking Calculator">
    <h1 class="mb-4">Infinite Banking Calculator</h1>
    <p class="text-lg mb-8 opacity-80">Project your whole life policy cash value and compare IBC financing vs. traditional bank loans.</p>

    <!-- Mode Toggle -->
    <div class="flex gap-2 mb-8">
        <button id="btn-basic" class="btn btn-primary btn-sm">Basic</button>
        <button id="btn-advanced" class="btn btn-outline btn-sm border-white/30 text-white">Advanced</button>
    </div>

    <!-- Input Section -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-8">
        <div class="bg-white/10 rounded-xl p-6">
            <h2 class="text-xl font-bold mb-4">Policy Details</h2>
            <div class="space-y-4">
                <div>
                    <label class="block text-sm opacity-70 mb-1">Current Age</label>
                    <input type="number" id="input-age" value="30" min="18" max="80" class="input input-bordered w-full bg-white/10 text-white border-white/20" />
                </div>
                <div>
                    <label class="block text-sm opacity-70 mb-1">Annual Premium</label>
                    <div class="relative">
                        <span class="absolute left-3 top-1/2 -translate-y-1/2 opacity-60">$</span>
                        <input type="number" id="input-premium" value="6000" min="1200" step="600" class="input input-bordered w-full bg-white/10 text-white border-white/20 pl-7" />
                    </div>
                </div>
                <div id="advanced-fields" class="hidden space-y-4">
                    <div>
                        <label class="block text-sm opacity-70 mb-1">Dividend Rate (%)</label>
                        <input type="number" id="input-dividend" value="5.0" min="0" max="10" step="0.1" class="input input-bordered w-full bg-white/10 text-white border-white/20" />
                    </div>
                    <div>
                        <label class="block text-sm opacity-70 mb-1">Policy Loan Rate (%)</label>
                        <input type="number" id="input-policy-rate" value="4.5" min="0" max="10" step="0.1" class="input input-bordered w-full bg-white/10 text-white border-white/20" />
                    </div>
                    <div>
                        <label class="block text-sm opacity-70 mb-1">Bank Loan Rate (%)</label>
                        <input type="number" id="input-bank-rate" value="7.0" min="0" max="20" step="0.1" class="input input-bordered w-full bg-white/10 text-white border-white/20" />
                    </div>
                    <div>
                        <label class="block text-sm opacity-70 mb-1">Base / PUA Split</label>
                        <div class="flex items-center gap-2">
                            <input type="number" id="input-base-pct" value="30" min="10" max="50" class="input input-bordered w-20 bg-white/10 text-white border-white/20 text-center" />
                            <span class="opacity-60">/</span>
                            <input type="number" id="input-pua-pct" value="70" min="50" max="90" class="input input-bordered w-20 bg-white/10 text-white border-white/20 text-center" readonly />
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Solve Scenarios -->
        <div class="bg-white/10 rounded-xl p-6">
            <h2 class="text-xl font-bold mb-4">Solve Scenarios</h2>
            <p class="text-sm opacity-60 mb-4">Select scenarios to compare IBC vs. traditional financing.</p>
            <div class="space-y-3" id="scenario-checkboxes">
                <label class="flex items-start gap-3 cursor-pointer">
                    <input type="checkbox" id="chk-car" class="checkbox checkbox-primary mt-0.5" />
                    <div>
                        <span class="font-semibold">Car Purchase</span>
                        <div id="car-fields" class="hidden mt-2 space-y-2">
                            <div class="flex gap-2">
                                <div class="flex-1">
                                    <label class="text-xs opacity-60">Price</label>
                                    <div class="relative">
                                        <span class="absolute left-2 top-1/2 -translate-y-1/2 opacity-60 text-sm">$</span>
                                        <input type="number" id="input-car-price" value="35000" class="input input-bordered input-sm w-full bg-white/10 text-white border-white/20 pl-6" />
                                    </div>
                                </div>
                                <div class="w-24">
                                    <label class="text-xs opacity-60">Term (yr)</label>
                                    <input type="number" id="input-car-term" value="5" min="1" max="8" class="input input-bordered input-sm w-full bg-white/10 text-white border-white/20" />
                                </div>
                            </div>
                            <div class="w-full">
                                <label class="text-xs opacity-60">Purchase in Year</label>
                                <input type="number" id="input-car-year" value="5" min="1" max="50" class="input input-bordered input-sm w-full bg-white/10 text-white border-white/20" />
                            </div>
                        </div>
                    </div>
                </label>

                <label class="flex items-start gap-3 cursor-pointer">
                    <input type="checkbox" id="chk-realestate" class="checkbox checkbox-primary mt-0.5" />
                    <div>
                        <span class="font-semibold">Real Estate / Mortgage</span>
                        <div id="realestate-fields" class="hidden mt-2 space-y-2">
                            <div class="flex gap-2">
                                <div class="flex-1">
                                    <label class="text-xs opacity-60">Down Payment</label>
                                    <div class="relative">
                                        <span class="absolute left-2 top-1/2 -translate-y-1/2 opacity-60 text-sm">$</span>
                                        <input type="number" id="input-re-amount" value="60000" class="input input-bordered input-sm w-full bg-white/10 text-white border-white/20 pl-6" />
                                    </div>
                                </div>
                                <div class="w-24">
                                    <label class="text-xs opacity-60">Term (yr)</label>
                                    <input type="number" id="input-re-term" value="10" min="1" max="30" class="input input-bordered input-sm w-full bg-white/10 text-white border-white/20" />
                                </div>
                            </div>
                            <div class="w-full">
                                <label class="text-xs opacity-60">Borrow in Year</label>
                                <input type="number" id="input-re-year" value="7" min="1" max="50" class="input input-bordered input-sm w-full bg-white/10 text-white border-white/20" />
                            </div>
                        </div>
                    </div>
                </label>

                <label class="flex items-start gap-3 cursor-pointer">
                    <input type="checkbox" id="chk-business" class="checkbox checkbox-primary mt-0.5" />
                    <div>
                        <span class="font-semibold">Business Financing</span>
                        <div id="business-fields" class="hidden mt-2 space-y-2">
                            <div class="flex gap-2">
                                <div class="flex-1">
                                    <label class="text-xs opacity-60">Amount</label>
                                    <div class="relative">
                                        <span class="absolute left-2 top-1/2 -translate-y-1/2 opacity-60 text-sm">$</span>
                                        <input type="number" id="input-biz-amount" value="50000" class="input input-bordered input-sm w-full bg-white/10 text-white border-white/20 pl-6" />
                                    </div>
                                </div>
                                <div class="w-24">
                                    <label class="text-xs opacity-60">Term (yr)</label>
                                    <input type="number" id="input-biz-term" value="7" min="1" max="20" class="input input-bordered input-sm w-full bg-white/10 text-white border-white/20" />
                                </div>
                            </div>
                            <div class="w-full">
                                <label class="text-xs opacity-60">Borrow in Year</label>
                                <input type="number" id="input-biz-year" value="5" min="1" max="50" class="input input-bordered input-sm w-full bg-white/10 text-white border-white/20" />
                            </div>
                        </div>
                    </div>
                </label>

                <label class="flex items-start gap-3 cursor-pointer">
                    <input type="checkbox" id="chk-emergency" class="checkbox checkbox-primary mt-0.5" />
                    <div>
                        <span class="font-semibold">Emergency Fund</span>
                        <div id="emergency-fields" class="hidden mt-2 space-y-2">
                            <div class="flex gap-2">
                                <div class="flex-1">
                                    <label class="text-xs opacity-60">Amount</label>
                                    <div class="relative">
                                        <span class="absolute left-2 top-1/2 -translate-y-1/2 opacity-60 text-sm">$</span>
                                        <input type="number" id="input-emg-amount" value="15000" class="input input-bordered input-sm w-full bg-white/10 text-white border-white/20 pl-6" />
                                    </div>
                                </div>
                                <div class="w-24">
                                    <label class="text-xs opacity-60">Term (yr)</label>
                                    <input type="number" id="input-emg-term" value="3" min="1" max="10" class="input input-bordered input-sm w-full bg-white/10 text-white border-white/20" />
                                </div>
                            </div>
                            <div class="w-full">
                                <label class="text-xs opacity-60">Borrow in Year</label>
                                <input type="number" id="input-emg-year" value="3" min="1" max="50" class="input input-bordered input-sm w-full bg-white/10 text-white border-white/20" />
                            </div>
                        </div>
                    </div>
                </label>

                <label class="flex items-start gap-3 cursor-pointer">
                    <input type="checkbox" id="chk-debt" class="checkbox checkbox-primary mt-0.5" />
                    <div>
                        <span class="font-semibold">Debt Payoff</span>
                        <div id="debt-fields" class="hidden mt-2 space-y-2">
                            <div class="flex gap-2">
                                <div class="flex-1">
                                    <label class="text-xs opacity-60">Debt Balance</label>
                                    <div class="relative">
                                        <span class="absolute left-2 top-1/2 -translate-y-1/2 opacity-60 text-sm">$</span>
                                        <input type="number" id="input-debt-amount" value="25000" class="input input-bordered input-sm w-full bg-white/10 text-white border-white/20 pl-6" />
                                    </div>
                                </div>
                                <div class="w-24">
                                    <label class="text-xs opacity-60">Term (yr)</label>
                                    <input type="number" id="input-debt-term" value="5" min="1" max="15" class="input input-bordered input-sm w-full bg-white/10 text-white border-white/20" />
                                </div>
                            </div>
                            <div class="flex gap-2">
                                <div class="flex-1">
                                    <label class="text-xs opacity-60">Current Debt Rate (%)</label>
                                    <input type="number" id="input-debt-rate" value="18" min="0" max="30" step="0.1" class="input input-bordered input-sm w-full bg-white/10 text-white border-white/20" />
                                </div>
                                <div class="w-full">
                                    <label class="text-xs opacity-60">Payoff in Year</label>
                                    <input type="number" id="input-debt-year" value="3" min="1" max="50" class="input input-bordered input-sm w-full bg-white/10 text-white border-white/20" />
                                </div>
                            </div>
                        </div>
                    </div>
                </label>
            </div>
        </div>
    </div>

    <!-- Calculate Button -->
    <div class="mb-10">
        <button id="btn-calculate" class="btn btn-primary btn-lg sm:btn-wide">Calculate</button>
    </div>

    <!-- Results Section -->
    <div id="results" class="hidden space-y-10 mb-16">

        <!-- Summary Cards -->
        <div id="summary-cards" class="grid grid-cols-1 sm:grid-cols-3 gap-4"></div>

        <!-- Base Projection Table -->
        <div>
            <h2 class="text-2xl font-bold mb-4">Cash Value Projection</h2>
            <div class="overflow-x-auto rounded-xl bg-white/5">
                <table class="table table-sm w-full">
                    <thead>
                        <tr class="border-b border-white/10 text-white/60">
                            <th class="bg-transparent">Year</th>
                            <th class="bg-transparent">Age</th>
                            <th class="bg-transparent text-right">Annual Premium</th>
                            <th class="bg-transparent text-right">Base Premium</th>
                            <th class="bg-transparent text-right">PUA</th>
                            <th class="bg-transparent text-right">Cash Value</th>
                            <th class="bg-transparent text-right">Death Benefit</th>
                        </tr>
                    </thead>
                    <tbody id="projection-body"></tbody>
                </table>
            </div>
        </div>

        <!-- Scenario Tables -->
        <div id="scenario-results"></div>
    </div>
</Layout>

<style>
    .table th, .table td {
        padding: 0.5rem 0.75rem;
        font-variant-numeric: tabular-nums;
    }
    .table tbody tr {
        border-bottom: 1px solid rgba(255,255,255,0.05);
    }
    .table tbody tr:hover {
        background: rgba(255,255,255,0.05);
    }
    .scenario-savings {
        color: #6ee7b7;
        font-weight: 700;
    }
    .checkbox-primary:checked {
        border-color: #F67280;
    }
    input[type="number"]::-webkit-inner-spin-button {
        opacity: 0.5;
    }
</style>

<script>
    // ─── Mode Toggle ───
    const btnBasic = document.getElementById('btn-basic') as HTMLButtonElement;
    const btnAdvanced = document.getElementById('btn-advanced') as HTMLButtonElement;
    const advancedFields = document.getElementById('advanced-fields')!;

    btnBasic.addEventListener('click', () => {
        advancedFields.classList.add('hidden');
        btnBasic.className = 'btn btn-primary btn-sm';
        btnAdvanced.className = 'btn btn-outline btn-sm border-white/30 text-white';
    });
    btnAdvanced.addEventListener('click', () => {
        advancedFields.classList.remove('hidden');
        btnAdvanced.className = 'btn btn-primary btn-sm';
        btnBasic.className = 'btn btn-outline btn-sm border-white/30 text-white';
    });

    // ─── Base/PUA Split Sync ───
    const basePctInput = document.getElementById('input-base-pct') as HTMLInputElement;
    const puaPctInput = document.getElementById('input-pua-pct') as HTMLInputElement;
    basePctInput.addEventListener('input', () => {
        puaPctInput.value = String(100 - Number(basePctInput.value));
    });

    // ─── Scenario Checkbox Toggles ───
    const scenarios = ['car', 'realestate', 'business', 'emergency', 'debt'];
    scenarios.forEach(s => {
        const chk = document.getElementById(`chk-${s}`) as HTMLInputElement;
        const fields = document.getElementById(`${s}-fields`)!;
        chk.addEventListener('change', (e) => {
            e.stopPropagation();
            fields.classList.toggle('hidden', !chk.checked);
        });
        // Prevent label click from toggling checkbox when clicking inputs
        fields.addEventListener('click', (e) => e.stopPropagation());
    });

    // ─── Helpers ───
    function $(id: string): number {
        return Number((document.getElementById(id) as HTMLInputElement).value);
    }
    function fmt(n: number): string {
        return n.toLocaleString('en-US', { style: 'currency', currency: 'USD', minimumFractionDigits: 0, maximumFractionDigits: 0 });
    }
    function fmtFull(n: number): string {
        return n.toLocaleString('en-US', { style: 'currency', currency: 'USD', minimumFractionDigits: 2, maximumFractionDigits: 2 });
    }

    // ─── Loan Amortization ───
    function monthlyPayment(principal: number, annualRate: number, years: number): number {
        const r = annualRate / 12;
        const n = years * 12;
        if (r === 0) return principal / n;
        return principal * (r * Math.pow(1 + r, n)) / (Math.pow(1 + r, n) - 1);
    }

    function totalInterest(principal: number, annualRate: number, years: number): number {
        const mp = monthlyPayment(principal, annualRate, years);
        return mp * years * 12 - principal;
    }

    // Yearly amortization schedule
    function amortizationSchedule(principal: number, annualRate: number, years: number) {
        const r = annualRate / 12;
        const n = years * 12;
        const mp = monthlyPayment(principal, annualRate, years);
        const schedule = [];
        let balance = principal;
        let cumInterest = 0;

        for (let yr = 1; yr <= years; yr++) {
            let yearInterest = 0;
            let yearPrincipal = 0;
            for (let m = 0; m < 12; m++) {
                if (balance <= 0.01) { balance = 0; break; }
                const intPmt = balance * r;
                const prinPmt = Math.min(mp - intPmt, balance);
                yearInterest += intPmt;
                yearPrincipal += prinPmt;
                balance -= prinPmt;
            }
            cumInterest += yearInterest;
            schedule.push({
                year: yr,
                payment: mp * 12,
                interest: yearInterest,
                principal: yearPrincipal,
                balance: Math.max(0, balance),
                cumInterest
            });
        }
        return schedule;
    }

    // ─── Cash Value Model ───
    function buildProjection(age: number, premium: number, divRate: number, basePct: number) {
        const years = 100 - age;
        const puaPct = 1 - basePct;
        const rows = [];
        let cashValue = 0;
        let deathBenefit = premium * 10; // Simplified initial face amount

        // PUA efficiency ramps up over time
        function puaEfficiency(yr: number): number {
            if (yr === 1) return 0.82;
            if (yr === 2) return 0.88;
            if (yr === 3) return 0.92;
            if (yr <= 5) return 0.94;
            if (yr <= 10) return 0.96;
            return 0.97;
        }

        // Base premium contributes to CV slowly at first
        function baseCVContribution(yr: number, basePrem: number): number {
            if (yr <= 2) return basePrem * 0.03;
            if (yr <= 5) return basePrem * 0.12;
            if (yr <= 10) return basePrem * 0.25;
            if (yr <= 20) return basePrem * 0.40;
            return basePrem * 0.55;
        }

        const premiumPayingYears = Math.min(years, 65); // Pay premiums to age 65 or projection end

        for (let yr = 1; yr <= years; yr++) {
            const paying = yr <= premiumPayingYears && (age + yr - 1) < 100;
            const annualPremium = paying ? premium : 0;
            const basePremium = annualPremium * basePct;
            const pua = annualPremium * puaPct;

            // Dividend on prior year cash value
            const dividend = cashValue * divRate;

            // Cash value growth
            const puaCashAdd = pua * puaEfficiency(yr);
            const baseCashAdd = baseCVContribution(yr, basePremium);
            cashValue = cashValue + dividend + puaCashAdd + baseCashAdd;

            // Death benefit grows with PUA additions and dividends
            if (paying) {
                deathBenefit += pua * 1.1 + dividend * 0.5;
            } else {
                deathBenefit = Math.max(deathBenefit, cashValue * 1.05);
            }

            rows.push({
                year: yr,
                age: age + yr,
                annualPremium,
                basePremium,
                pua,
                cashValue,
                deathBenefit
            });
        }
        return rows;
    }

    // ─── Calculate ───
    document.getElementById('btn-calculate')!.addEventListener('click', () => {
        const age = $('input-age');
        const premium = $('input-premium');
        const divRate = $('input-dividend') / 100;
        const policyLoanRate = $('input-policy-rate') / 100;
        const bankRate = $('input-bank-rate') / 100;
        const basePct = $('input-base-pct') / 100;

        // Build base projection
        const projection = buildProjection(age, premium, divRate, basePct);

        // ─── Render Summary Cards ───
        const finalRow = projection[projection.length - 1];
        const totalPremiums = projection.reduce((s, r) => s + r.annualPremium, 0);
        const summaryHTML = `
            <div class="bg-white/10 rounded-xl p-5">
                <div class="text-sm opacity-60 mb-1">Total Premiums Paid</div>
                <div class="text-2xl font-bold">${fmt(totalPremiums)}</div>
            </div>
            <div class="bg-white/10 rounded-xl p-5">
                <div class="text-sm opacity-60 mb-1">Cash Value at Age 100</div>
                <div class="text-2xl font-bold text-green-300">${fmt(finalRow.cashValue)}</div>
            </div>
            <div class="bg-white/10 rounded-xl p-5">
                <div class="text-sm opacity-60 mb-1">Death Benefit at Age 100</div>
                <div class="text-2xl font-bold">${fmt(finalRow.deathBenefit)}</div>
            </div>
        `;
        document.getElementById('summary-cards')!.innerHTML = summaryHTML;

        // ─── Render Base Projection Table ───
        const projBody = document.getElementById('projection-body')!;
        projBody.innerHTML = projection.map(r => `
            <tr>
                <td>${r.year}</td>
                <td>${r.age}</td>
                <td class="text-right">${r.annualPremium > 0 ? fmt(r.annualPremium) : '—'}</td>
                <td class="text-right">${r.basePremium > 0 ? fmt(r.basePremium) : '—'}</td>
                <td class="text-right">${r.pua > 0 ? fmt(r.pua) : '—'}</td>
                <td class="text-right font-semibold">${fmt(r.cashValue)}</td>
                <td class="text-right">${fmt(r.deathBenefit)}</td>
            </tr>
        `).join('');

        // ─── Render Scenario Tables ───
        const scenarioContainer = document.getElementById('scenario-results')!;
        scenarioContainer.innerHTML = '';

        interface ScenarioConfig {
            id: string;
            label: string;
            amount: number;
            term: number;
            startYear: number;
            compareRate: number;
        }

        const activeScenarios: ScenarioConfig[] = [];

        if ((document.getElementById('chk-car') as HTMLInputElement).checked) {
            activeScenarios.push({
                id: 'car',
                label: 'Car Purchase',
                amount: $('input-car-price'),
                term: $('input-car-term'),
                startYear: $('input-car-year'),
                compareRate: bankRate
            });
        }
        if ((document.getElementById('chk-realestate') as HTMLInputElement).checked) {
            activeScenarios.push({
                id: 'realestate',
                label: 'Real Estate / Mortgage',
                amount: $('input-re-amount'),
                term: $('input-re-term'),
                startYear: $('input-re-year'),
                compareRate: bankRate
            });
        }
        if ((document.getElementById('chk-business') as HTMLInputElement).checked) {
            activeScenarios.push({
                id: 'business',
                label: 'Business Financing',
                amount: $('input-biz-amount'),
                term: $('input-biz-term'),
                startYear: $('input-biz-year'),
                compareRate: bankRate
            });
        }
        if ((document.getElementById('chk-emergency') as HTMLInputElement).checked) {
            activeScenarios.push({
                id: 'emergency',
                label: 'Emergency Fund',
                amount: $('input-emg-amount'),
                term: $('input-emg-term'),
                startYear: $('input-emg-year'),
                compareRate: bankRate
            });
        }
        if ((document.getElementById('chk-debt') as HTMLInputElement).checked) {
            const debtRate = $('input-debt-rate') / 100;
            activeScenarios.push({
                id: 'debt',
                label: 'Debt Payoff',
                amount: $('input-debt-amount'),
                term: $('input-debt-term'),
                startYear: $('input-debt-year'),
                compareRate: debtRate
            });
        }

        activeScenarios.forEach(scenario => {
            const { label, amount, term, startYear, compareRate } = scenario;

            // Check if enough cash value
            const cvAtStart = startYear <= projection.length ? projection[startYear - 1].cashValue : 0;
            if (cvAtStart < amount) {
                scenarioContainer.innerHTML += `
                    <div class="bg-red-500/20 border border-red-400/30 rounded-xl p-6 mb-6">
                        <h2 class="text-xl font-bold mb-2">${label}</h2>
                        <p>Insufficient cash value in year ${startYear}. You have <strong>${fmt(cvAtStart)}</strong> but need <strong>${fmt(amount)}</strong>.</p>
                        <p class="text-sm opacity-70 mt-1">Consider increasing your premium, pushing the purchase year out, or reducing the amount.</p>
                    </div>
                `;
                return;
            }

            // Bank loan amortization
            const bankSchedule = amortizationSchedule(amount, compareRate, term);
            const bankTotalInterest = bankSchedule[bankSchedule.length - 1].cumInterest;
            const bankMonthly = monthlyPayment(amount, compareRate, term);

            // Policy loan amortization (same monthly payment as bank, but at policy loan rate)
            const policySchedule = amortizationSchedule(amount, policyLoanRate, term);
            const policyTotalInterest = policySchedule[policySchedule.length - 1].cumInterest;
            const policyMonthly = monthlyPayment(amount, policyLoanRate, term);

            // Dividends earned on the loaned amount (cash value still earns dividends on full amount)
            let dividendOnLoan = 0;
            let loanBal = amount;
            for (let yr = 0; yr < term; yr++) {
                dividendOnLoan += loanBal * divRate;
                if (yr < policySchedule.length) {
                    loanBal = policySchedule[yr].balance;
                }
            }

            const interestSaved = bankTotalInterest - policyTotalInterest;
            const totalRecapture = interestSaved + dividendOnLoan;

            // Build comparison table rows
            let tableRows = '';
            for (let yr = 0; yr < term; yr++) {
                const bs = bankSchedule[yr];
                const ps = policySchedule[yr];
                tableRows += `
                    <tr>
                        <td>${yr + 1}</td>
                        <td class="text-right">${fmtFull(bs.balance)}</td>
                        <td class="text-right">${fmtFull(bs.interest)}</td>
                        <td class="text-right">${fmtFull(bs.cumInterest)}</td>
                        <td class="text-right">${fmtFull(ps.balance)}</td>
                        <td class="text-right">${fmtFull(ps.interest)}</td>
                        <td class="text-right">${fmtFull(ps.cumInterest)}</td>
                        <td class="text-right scenario-savings">${fmtFull(bs.cumInterest - ps.cumInterest)}</td>
                    </tr>
                `;
            }

            scenarioContainer.innerHTML += `
                <div class="mb-10">
                    <h2 class="text-2xl font-bold mb-2">${label}</h2>
                    <p class="opacity-70 mb-4">Borrowing <strong>${fmt(amount)}</strong> in policy year ${startYear} (age ${age + startYear}) over ${term} years.</p>

                    <div class="grid grid-cols-1 sm:grid-cols-4 gap-3 mb-5">
                        <div class="bg-white/10 rounded-lg p-4">
                            <div class="text-xs opacity-50 mb-1">Bank Monthly Payment</div>
                            <div class="font-bold">${fmtFull(bankMonthly)}</div>
                        </div>
                        <div class="bg-white/10 rounded-lg p-4">
                            <div class="text-xs opacity-50 mb-1">Policy Monthly Payment</div>
                            <div class="font-bold">${fmtFull(policyMonthly)}</div>
                        </div>
                        <div class="bg-white/10 rounded-lg p-4">
                            <div class="text-xs opacity-50 mb-1">Interest Saved</div>
                            <div class="font-bold text-green-300">${fmt(interestSaved)}</div>
                        </div>
                        <div class="bg-emerald-500/20 border border-emerald-400/30 rounded-lg p-4">
                            <div class="text-xs opacity-70 mb-1">Total Interest Recapture</div>
                            <div class="text-xl font-bold text-green-300">${fmt(totalRecapture)}</div>
                            <div class="text-xs opacity-50 mt-1">Interest saved + ${fmt(dividendOnLoan)} dividends earned</div>
                        </div>
                    </div>

                    <div class="overflow-x-auto rounded-xl bg-white/5">
                        <table class="table table-sm w-full">
                            <thead>
                                <tr class="border-b border-white/10 text-white/60">
                                    <th class="bg-transparent">Year</th>
                                    <th class="bg-transparent text-right">Bank Balance</th>
                                    <th class="bg-transparent text-right">Bank Interest</th>
                                    <th class="bg-transparent text-right">Bank Cum. Interest</th>
                                    <th class="bg-transparent text-right">Policy Balance</th>
                                    <th class="bg-transparent text-right">Policy Interest</th>
                                    <th class="bg-transparent text-right">Policy Cum. Interest</th>
                                    <th class="bg-transparent text-right">Recapture</th>
                                </tr>
                            </thead>
                            <tbody>${tableRows}</tbody>
                        </table>
                    </div>
                </div>
            `;
        });

        // Show results
        document.getElementById('results')!.classList.remove('hidden');
        document.getElementById('results')!.scrollIntoView({ behavior: 'smooth', block: 'start' });
    });
</script>
